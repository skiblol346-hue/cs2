{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build ImGui-DX11-Base-Win Release x64",
      "type": "shell",
      "command": "${env:ProgramFiles}\\Microsoft Visual Studio\\2022\\Community\\MSBuild\\Current\\Bin\\MSBuild.exe",
      "args": [
        "${workspaceFolder}/ImGui-DX11-Base-Win.sln",
        "/t:Build",
        "/p:Configuration=Release",
        "/p:Platform=x64",
        "/m",
        "/v:minimal"
      ],
      "group": "build",
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "showReuseMessage": false
      }
    },
    {
      "label": "Build ImGui-DX11-Base-Win Release x86",
      "type": "shell",
      "command": "${env:ProgramFiles}\\Microsoft Visual Studio\\2022\\Community\\MSBuild\\Current\\Bin\\MSBuild.exe",
      "args": [
        "${workspaceFolder}/ImGui-DX11-Base-Win.sln",
        "/t:Build",
        "/p:Configuration=Release",
        "/p:Platform=x86",
        "/m",
        "/v:minimal"
      ],
      "group": "build",
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "showReuseMessage": false
      }
    },
    {
      "label": "Rebuild ImGui-DX11-Base-Win Release x64",
      "type": "shell",
      "command": "${env:ProgramFiles}\\Microsoft Visual Studio\\2022\\Community\\MSBuild\\Current\\Bin\\MSBuild.exe",
      "args": [
        "${workspaceFolder}/ImGui-DX11-Base-Win.sln",
        "/t:Rebuild",
        "/p:Configuration=Release",
        "/p:Platform=x64",
        "/m",
        "/v:minimal"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "showReuseMessage": false
      }
    },
    {
      "label": "Clean ImGui-DX11-Base-Win",
      "type": "shell",
      "command": "${env:ProgramFiles}\\Microsoft Visual Studio\\2022\\Community\\MSBuild\\Current\\Bin\\MSBuild.exe",
      "args": [
        "${workspaceFolder}/ImGui-DX11-Base-Win.sln",
        "/t:Clean",
        "/p:Configuration=Release",
        "/p:Platform=x64",
        "/v:minimal"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
