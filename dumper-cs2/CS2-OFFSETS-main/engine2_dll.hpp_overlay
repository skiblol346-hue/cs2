                        void* m_LoopState; // EngineLoopState_t
                    };
                    struct {
                        char pad_0028[0x28];
                        void* m_flRealTime; // float32
                    };
                    struct {
                        char pad_002C[0x2C];
                        void* m_flTickInterval; // float32
                    };
                    struct {
                        char pad_0030[0x30];
                        void* m_flTickStartTime; // float64
                    };
                };
            };
            #pragma pack(pop)

            #pragma pack(push, 1)
            class EventServerEndSimulate_t {
                public:
                union {
                    struct {
                        bool m_bLastTick; // bool
                    };
                };
            };
            #pragma pack(pop)

            #pragma pack(push, 1)
            class EventServerPollNetworking_t {
                public:
                union {
                    char pad_empty[1];
                };
            };
            #pragma pack(pop)

        }
    }
}
